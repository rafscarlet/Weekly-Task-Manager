{
  "name": "calendar-tasks",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "build": "ng build",
    "start": "npm run build && electron .",
    "watch": "ng build --watch --configuration development",
    "dev:angular": "ng serve --configuration development",
    "dev:electron": "wait-on http://localhost:4200 && cross-env ELECTRON_START_URL=http://localhost:4200 electron .",
    "dev:main": "nodemon --watch main.js --watch preload.js --ext js --exec \"wait-on http://localhost:4200 && cross-env ELECTRON_START_URL=http://localhost:4200 electron .\"",
    "dev": "concurrently -k \"npm run dev:angular\" \"npm run dev:main\"",
    "dist": "npm run build && electron-builder", 
    "dist:linux": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.rafscarlet.calendartasks",
    "productName": "Calendar Tasks",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.14",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.15.3",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.14",
    "@angular/compiler": "^21.2.14",
    "@angular/core": "^21.2.14",
    "@angular/forms": "^21.2.14",
    "@angular/platform-browser": "^21.2.14",
    "@angular/platform-browser-dynamic": "^21.2.14",
    "@angular/router": "^21.2.17",
    "material-symbols": "^0.45.8",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  }
}
